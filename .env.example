# PostgreSQL connection string
DATABASE_URL=postgres://allstrm:your_secure_password@localhost:5432/allstrm

# Postgres password (for docker-compose)
POSTGRES_PASSWORD=your_secure_password

# ------------------------------------------------------------------------------
# Redis (Optional - enables distributed mode)
# ------------------------------------------------------------------------------
# If not set, runs in standalone mode
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Supabase Authentication (Required for production)
# ------------------------------------------------------------------------------
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# JWT secret from Supabase Dashboard > Settings > API > JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# Allowed JWT audiences (comma-separated)
# SUPABASE_AUDIENCES=authenticated

# ------------------------------------------------------------------------------
# Cloudflare R2 Storage (Required for recordings)
# ------------------------------------------------------------------------------
# R2 endpoint - format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# R2 credentials from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key

# Bucket name for recordings
R2_BUCKET=allstrm-recordings

# Storage prefix (optional)
R2_STORAGE_PREFIX=recordings

# ------------------------------------------------------------------------------
# RTMP Output
# ------------------------------------------------------------------------------
# Default RTMP destination for streams
# Examples:
# - YouTube: rtmp://a.rtmp.youtube.com/live2
# - Twitch: rtmp://live.twitch.tv/app
# - Custom: rtmp://your-rtmp-server/live
RTMP_URL=rtmp://localhost/live

# ------------------------------------------------------------------------------
# Runtime Configuration
# ------------------------------------------------------------------------------
# Number of Tokio worker threads (0 = auto-detect based on CPU cores)
WORKER_THREADS=0

# Prometheus metrics port
METRICS_PORT=9090

# Node address for clustering (host:port)
NODE_ADDRESS=0.0.0.0:8080

# ------------------------------------------------------------------------------
# WebRTC Configuration
# ------------------------------------------------------------------------------
WEBRTC_PORT=8080
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302

# ------------------------------------------------------------------------------
# SRT Configuration (v2 - currently stub)
# ------------------------------------------------------------------------------
SRT_BASE_PORT=9000
# SRT_PASSPHRASE=your-secure-passphrase

# ------------------------------------------------------------------------------
# FFmpeg Configuration
# ------------------------------------------------------------------------------
FFMPEG_PATH=/usr/bin/ffmpeg
ZMQ_BASE_PORT=5555

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
# Log level: error, warn, info, debug, trace
RUST_LOG=info,allstrm=debug

# Enable backtraces on panic
RUST_BACKTRACE=1

# ------------------------------------------------------------------------------
# Grafana (for monitoring profile)
# ------------------------------------------------------------------------------
GRAFANA_PASSWORD=your_grafana_admin_password

# ------------------------------------------------------------------------------
# Service Ports
# ------------------------------------------------------------------------------
GATEWAY_PORT=8080
CORE_PORT=8081
SFU_PORT=8082
STREAM_PORT=8083
STORAGE_PORT=8084

# ------------------------------------------------------------------------------
# Gateway Configuration
# ------------------------------------------------------------------------------
GATEWAY_JWT_SECRET=development-secret
# GATEWAY_JWT_AUDIENCE=authenticated
GATEWAY_RATE_LIMIT_RPS=100
GATEWAY_RATE_LIMIT_BURST=200

# Internal service URLs (for gateway to proxy)
CORE_SERVICE_URL=http://localhost:8081
SFU_SERVICE_URL=http://localhost:8082
STREAM_SERVICE_URL=http://localhost:8083
STORAGE_SERVICE_URL=http://localhost:8084

# ------------------------------------------------------------------------------
# Database Migrations
# ------------------------------------------------------------------------------
# Run migrations on service startup (default: true)
# Set to false in production and use `make db-migrate` instead
RUN_MIGRATIONS=true

# ------------------------------------------------------------------------------
# OAuth Provider Configuration (Optional)
# Configure credentials for automatic stream key fetching
# ------------------------------------------------------------------------------

# Base URL for OAuth callbacks (must match your OAuth app redirect URIs)
OAUTH_REDIRECT_BASE_URL=http://localhost:8080

# YouTube (Google OAuth) - https://console.cloud.google.com/
# Required scopes: youtube, youtube.force-ssl
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook Live (also used for Instagram) - https://developers.facebook.com/
# Required scopes: publish_video, pages_manage_posts, pages_read_engagement
# Instagram also needs: instagram_basic, instagram_content_publish
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LinkedIn Live - https://www.linkedin.com/developers/
# Required scopes: r_liteprofile, w_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X/Twitter - https://developer.twitter.com/
# Required scopes: tweet.read, users.read, offline.access
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Twitch - https://dev.twitch.tv/console
# Required scopes: channel:manage:broadcast, channel:read:stream_key, user:read:email
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# TikTok Live - https://developers.tiktok.com/
# Required scopes: user.info.basic, video.publish
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Vimeo - https://developer.vimeo.com/
# Required scopes: public, private, video_files
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=

# Amazon Live - https://developer.amazon.com/
# Required scopes: profile
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

# Brightcove (Client Credentials) - https://studio.brightcove.com/
BRIGHTCOVE_ACCOUNT_ID=
BRIGHTCOVE_CLIENT_SECRET=

# Hopin - https://hopin.com/developers
# Required scopes: events.read, events.write
HOPIN_CLIENT_ID=
HOPIN_CLIENT_SECRET=

# Note: Kick and Custom RTMP don't require OAuth - they use manual RTMP configuration

# ------------------------------------------------------------------------------
# Development Only
# ------------------------------------------------------------------------------
# Skip JWT validation (DO NOT USE IN PRODUCTION)
# SKIP_AUTH=true
