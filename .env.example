# =============================================================================
# ALLSTRM Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# =============================================================================
# Core Configuration
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# LiveKit Configuration
# =============================================================================
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=http://localhost:7880

# =============================================================================
# Supabase Configuration
# Get these from: supabase status (after running supabase start)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Service role key - needed for OAuth token storage (server-side only)
# Get from: supabase status | grep service_role
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# OAuth - Streaming Platform Integrations (OPTIONAL)
# =============================================================================
# If not set, users will use manual RTMP entry (which always works)
# Set these to enable "Connect with [Platform]" OAuth button

# -----------------------------------------------------------------------------
# YouTube / Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Scopes needed: YouTube Data API v3
# Callback URL: http://localhost:3000/api/oauth/youtube/callback
# -----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Twitch OAuth
# Create at: https://dev.twitch.tv/console/apps
# Scopes: channel:read:stream_key, user:read:email
# Callback URL: http://localhost:3000/api/oauth/twitch/callback
# -----------------------------------------------------------------------------
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Facebook OAuth
# Create at: https://developers.facebook.com/apps/
# Permissions: publish_video, pages_show_list
# Callback URL: http://localhost:3000/api/oauth/facebook/callback
# Note: Requires app review for production
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# -----------------------------------------------------------------------------
# LinkedIn OAuth
# Create at: https://www.linkedin.com/developers/apps
# Products: Sign In with LinkedIn, Marketing Developer Platform
# Callback URL: http://localhost:3000/api/oauth/linkedin/callback
# Note: LinkedIn Live requires approved creator accounts
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# X (Twitter) OAuth 2.0
# Create at: https://developer.twitter.com/en/portal/dashboard
# Scopes: tweet.read, users.read, offline.access
# Callback URL: http://localhost:3000/api/oauth/x/callback
# Note: X Live has limited API support
# -----------------------------------------------------------------------------
X_CLIENT_ID=
X_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Vimeo OAuth
# Create at: https://developer.vimeo.com/apps
# Scopes: public, private, video_files, interact
# Callback URL: http://localhost:3000/api/oauth/vimeo/callback
# Note: Vimeo Live requires Premium+ plan
# -----------------------------------------------------------------------------
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=

# =============================================================================
# Stripe Configuration (for billing/subscriptions)
# =============================================================================
# Get these from: https://dashboard.stripe.com/apikeys
# Webhook secret from: https://dashboard.stripe.com/webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Storage Configuration (for recordings)
# =============================================================================
# MinIO (local dev)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=allstrm-recordings

# Cloudflare R2 (production)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=allstrm-recordings

# =============================================================================
# Redis (for LiveKit session state)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# Development Only
# =============================================================================
# Skip auth in development (NEVER use in production)
# SKIP_AUTH=true
