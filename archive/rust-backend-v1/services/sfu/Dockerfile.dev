# ALLSTRM SFU Service - Development Dockerfile with Hot Reload
FROM rust:1.92-slim-bookworm

WORKDIR /app

# Install dependencies for WebRTC and cargo-watch
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    cmake \
    clang \
    && rm -rf /var/lib/apt/lists/*

# Install cargo-watch for hot reload (use --locked to avoid dependency issues)
RUN cargo install cargo-watch --locked

# WebRTC ports
EXPOSE 8082
EXPOSE 10000-10100/udp

# Use cargo-watch to automatically rebuild and restart on file changes
CMD ["cargo", "watch", "-x", "run -p allstrm-sfu", "-w", "services/sfu", "-w", "services/common", "-w", "services/protocol"]
