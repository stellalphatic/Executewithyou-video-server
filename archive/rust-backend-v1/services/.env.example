# ALLSTRM Microservices - Environment Configuration
# Copy this file to services/.env and adjust values for your environment

# ============================================================================
# Common Settings
# ============================================================================

RUST_LOG=info,sqlx=warn
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================================================
# Database
# ============================================================================

DATABASE_URL=postgres://allstrm:allstrm@localhost:5432/allstrm
DATABASE_POOL_SIZE=10

# ============================================================================
# Redis
# ============================================================================

REDIS_URL=redis://localhost:6379

# ============================================================================
# Gateway Service (:8080)
# ============================================================================

GATEWAY_PORT=8080
CORE_SERVICE_URL=http://localhost:8081
SFU_SERVICE_URL=http://localhost:8082
STREAM_SERVICE_URL=http://localhost:8083
STORAGE_SERVICE_URL=http://localhost:8084

# ============================================================================
# Core Service (:8081)
# ============================================================================

CORE_PORT=8081

# ============================================================================
# SFU Service (:8082) - Meeting Mode (S1)
# ============================================================================

SFU_PORT=8082
PUBLIC_IP=127.0.0.1

# STUN/TURN servers for WebRTC
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# ============================================================================
# Stream Service (:8083) - Studio Mode (S2)
# ============================================================================

STREAM_PORT=8083
RTMP_PORT=1935
HLS_OUTPUT_DIR=/tmp/allstrm/hls
FFMPEG_PATH=ffmpeg
HLS_SEGMENT_DURATION=2
HLS_PLAYLIST_SIZE=6
MAX_BITRATE=6000
DEFAULT_RESOLUTION=1920x1080

# ============================================================================
# Storage Service (:8084)
# ============================================================================

STORAGE_PORT=8084

# S3/R2 Configuration
# For local development with MinIO:
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=allstrm
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# For Cloudflare R2 (production):
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_BUCKET=your-bucket-name
# S3_REGION=auto
# S3_ACCESS_KEY=your-r2-access-key
# S3_SECRET_KEY=your-r2-secret-key

PRESIGNED_URL_EXPIRY_SECS=3600
MAX_UPLOAD_SIZE_MB=500
